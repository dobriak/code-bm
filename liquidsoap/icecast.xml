<?xml version="1.0" encoding="UTF-8"?>
<icecast>
    <limits>
        <clients>100</clients>
        <sources>2</sources>
        <queue-size>102400</queue-size>
        <client-timeout>30</client-timeout>
        <header-timeout>15</header-timeout>
        <source-timeout>10</source-timeout>
        <burst-on-connect>1</burst-on-connect>
        <burst-size>65536</burst-size>
    </limits>

    <authentication>
        <source-password>${ICECAST_SOURCE_PASSWORD}</source-password>
        <admin-user>admin</admin-user>
        <admin-password>${ICECAST_ADMIN_PASSWORD:-admin}</admin-password>
    </authentication>

    <hostname>localhost</hostname>
    <location>Raidio</location>
    <admin>admin@localhost</admin>
    <server-id>raidio</server-id>

    <logging>
        <accesslog>icecast_access.log</accesslog>
        <errorlog>icecast_error.log</errorlog>
        <playlistlog>icecast_playlist.log</playlistlog>
        <loglevel>3</loglevel>
    </logging>

    <paths>
        <basedir>/usr/local/share/icecast</basedir>
        <logdir>./logs</logdir>
        <webroot>./web</webroot>
        <adminroot>./admin</adminroot>
        <pidfile>./icecast.pid</pidfile>
    </paths>

    <listen-socket>
        <port>8000</port>
        <bind-address>0.0.0.0</bind-address>
    </listen-socket>

    <mount type="normal">
        <mount-name>/raidio.mp3</mount-name>
        <password>${ICECAST_SOURCE_PASSWORD}</password>
        <max-listeners>10</max-listeners>
        <burst-size>65536</burst-size>
        <public>0</public>
        <stream-name>Raidio</stream-name>
        <stream-description>Personal LAN Radio</stream-name>
        <genre>radio</genre>
        <bitrate>128</bitrate>
        <type>audio/mpeg</type>
        <intro></intro>
        <fallback-mount></fallback-mount>
        <fallback-override>0</fallback-override>
        <fallback-when-full>0</fallback-when-full>
        <mp3-metadata-interval>4096</mp3-metadata-interval>
        <http-headers>
            <header name="Access-Control-Allow-Origin" value="*" />
            <header name="X-Robots-Tag" value="noindex, noarchive" />
        </http-headers>
    </mount>
</icecast>