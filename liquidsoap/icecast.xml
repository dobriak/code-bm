<!-- Raidio — Icecast 2 configuration -->
<!-- Passwords and host are injected via environment by Taskfile. -->
<!-- See DESIGN.md §11 for all configuration variables. -->

<icecast>
    <location>Raidio LAN Radio</location>
    <admin>admin@raidio.local</admin>

    <limits>
        <clients>10</clients>
        <sources>2</sources>
        <queue-size>524288</queue-size>
        <client-timeout>30</client-timeout>
        <header-timeout>15</header-timeout>
        <source-timeout>10</source-timeout>
        <burst-on-connect>1</burst-on-connect>
        <burst-size>65535</burst-size>
    </limits>

    <authentication>
        <source-password>${ICECAST_SOURCE_PASSWORD}</source-password>
        <relay-password>${ICECAST_SOURCE_PASSWORD}</relay-password>
        <admin-user>admin</admin-user>
        <admin-password>${ICECAST_SOURCE_PASSWORD}</admin-password>
    </authentication>

    <hostname>${ICECAST_HOST}</hostname>

    <listen-socket>
        <port>${ICECAST_PORT}</port>
        <bind-address>127.0.0.1</bind-address>
    </listen-socket>

    <!-- Permissive CORS — required for Web Audio API visualizer -->
    <http-headers>
        <header name="Access-Control-Allow-Origin" value="*" />
    </http-headers>

    <fileserve>1</fileserve>

    <paths>
        <basedir>/usr/share/icecast2</basedir>
        <logdir>tmp/raidio-logs</logdir>
        <webroot>/usr/share/icecast2/web</webroot>
        <adminroot>/usr/share/icecast2/admin</adminroot>
    </paths>

    <logging>
        <accesslog>access.log</accesslog>
        <errorlog>error.log</errorlog>
        <loglevel>3</loglevel>
        <logsize>10000</logsize>
    </logging>

    <security>
        <chroot>0</chroot>
    </security>
</icecast>
